    const start = performance.now();
    let frame;
    function step(now) {
      const t = Math.min(1, (now - start) / duration);
      onUpdate(from + (to - from) * ease(t));
      if (t < 1) frame = requestAnimationFrame(step);
    }
    frame = requestAnimationFrame(step);
    return () => cancelAnimationFrame(frame);
  }

  // Animated count-up for the hero number
  let animFrame = null;
  function animateNumber(from, to, duration) {
    if (animFrame) cancelAnimationFrame(animFrame);
    const start = performance.now();
    function step(now) {
      const elapsed = now - start;
      const t = Math.min(1, elapsed / duration);
      const eased = easeOutCubic(t);
      const v = Math.round(from + (to - from) * eased);
      heroNum.textContent = fmt.format(v);
      if (t < 1) animFrame = requestAnimationFrame(step);
      else animFrame = null;
    }
    animFrame = requestAnimationFrame(step);
  }

  // ---------- VIZ (SVG) ----------
  // viewBox 1200 x 360
  // The "failure cost" is rendered as a wide horizontal bar at true width.
  // A magnifier callout to the left shows what 1 year of SGaaS looks like at true scale
  // (sub-pixel) versus its enlarged-for-visibility version.
  function renderViz(state, opts) {
    opts = opts || {};
    const animate = opts.animate !== false; // default true

    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const VB_W = 1200, VB_H = 360;
    const barX = 80, barY = 110, barW = 1040, barH = 70;
    const ratio = state.ratio; // years

    // ----- Wipe-in clipPath (animates left → right on case change) -----
    const defs = el('defs', {}, svg);
    const clip = el('clipPath', { id: 'viz-wipe' }, defs);
    // The wipe rect's width is animated. The clip extends slightly past barX+barW so
    // overflowing text (right-end "TOTAL FAILURE COST" labels) is revealed cleanly.
    const wipeStart = animate ? 0 : (barX + barW + 80);
    const wipeRect = el('rect', {
      x: 0, y: 0, width: wipeStart, height: VB_H
    }, clip);

    // All animated content lives inside this clipped group
    const root = el('g', { 'clip-path': 'url(#viz-wipe)' }, svg);

    // Background "scale" track behind the bar for context
    el('rect', {
      x: barX, y: barY, width: barW, height: barH,
      fill: '#F1F3F5', stroke: '#DEE2E6', 'stroke-width': 1, rx: 2
    }, root);

    // The "1 year SGaaS" sliver at the leftmost edge — at true scale this is
    // sub-pixel; we render it as 6px for visibility and annotate the enlargement.
    const sliverTrueWidth = barW / ratio;
    const sliverDisplayWidth = 6;
    el('rect', {
      x: barX, y: barY, width: sliverDisplayWidth, height: barH,
      fill: 'var(--ml-gold)', rx: 1
    }, root);

    // Rest of bar = the failure cost continues to the right
    el('rect', {
      x: barX + sliverDisplayWidth, y: barY,
      width: barW - sliverDisplayWidth, height: barH,
      fill: 'var(--ml-charcoal)', rx: 0
    }, root);

    // --- Top label: SGaaS retainer (over the gold sliver) ---
    el('line', {
      x1: barX + sliverDisplayWidth/2, y1: barY - 8,
      x2: barX + sliverDisplayWidth/2, y2: barY - 36,
      stroke: 'var(--ml-gold)', 'stroke-width': 1
    }, root);
    el('text', {
      x: barX + 14, y: barY - 42,
      'font-size': 12, 'font-weight': 600, 'letter-spacing': '0.04em',
      fill: 'var(--ml-gold)', 'text-anchor': 'start'
    }, root).textContent = '£' + fmt.format(state.retainer) + ' · 1 YEAR OF SGAAS';
    el('text', {
      x: barX + 14, y: barY - 26,
      'font-size': 10.5, fill: 'var(--ml-slate-grey)', 'text-anchor': 'start',
      'font-style': 'italic'
    }, root).textContent = 'shown 6 px wide for visibility · true scale: ' + sliverTrueWidth.toFixed(3) + ' px';

    // --- Top label: Failure cost (right-aligned over end of bar) ---
    el('line', {
      x1: barX + barW - 1, y1: barY - 8,
      x2: barX + barW - 1, y2: barY - 36,
      stroke: 'var(--ml-charcoal)', 'stroke-width': 1
    }, root);
    el('text', {
      x: barX + barW - 14, y: barY - 42,
      'font-size': 12, 'font-weight': 600, 'letter-spacing': '0.04em',
      fill: 'var(--ml-charcoal)', 'text-anchor': 'end'
    }, root).textContent = state.costLabel.toUpperCase() + ' · TOTAL FAILURE COST';
    el('text', {
      x: barX + barW - 14, y: barY - 26,
      'font-size': 10.5, fill: 'var(--ml-slate-grey)', 'text-anchor': 'end',
      'font-style': 'italic'
    }, root).textContent = state.costSub;

    // --- Ruler beneath the bar showing year markers ---
    const rulerY = barY + barH + 12;
    el('line', {
      x1: barX, y1: rulerY, x2: barX + barW, y2: rulerY,
      stroke: 'var(--ml-line)', 'stroke-width': 1
    }, root);

    // Choose tick intervals based on ratio magnitude
    let tickInterval;
    if (ratio > 40000) tickInterval = 10000;
    else if (ratio > 15000) tickInterval = 5000;
    else if (ratio > 7000)  tickInterval = 2000;
    else if (ratio > 3000)  tickInterval = 1000;
    else tickInterval = 500;

    for (let y = 0; y <= ratio; y += tickInterval) {
      const tx = barX + (y / ratio) * barW;
      el('line', {
        x1: tx, y1: rulerY, x2: tx, y2: rulerY + 6,
        stroke: 'var(--ml-slate-grey)', 'stroke-width': 1
      }, root);
      if (y > 0) {
        el('text', {
          x: tx, y: rulerY + 22,
          'font-size': 11, fill: 'var(--ml-slate-grey)', 'text-anchor': 'middle'
        }, root).textContent = y >= 1000 ? (y / 1000) + 'K' : y;
      }
    }
    // Year unit label
    el('text', {
      x: barX, y: rulerY + 22,
      'font-size': 11, fill: 'var(--ml-slate-grey)', 'text-anchor': 'start',
      'font-weight': 600
    }, root).textContent = 'YEARS';
    // Final tick mark for the actual ratio (always show the exact endpoint)
    const endTx = barX + barW;
    el('line', {
      x1: endTx, y1: rulerY, x2: endTx, y2: rulerY + 6,
      stroke: 'var(--ml-charcoal)', 'stroke-width': 1.5
    }, root);
    el('text', {
      x: endTx, y: rulerY + 22,
      'font-size': 11.5, fill: 'var(--ml-charcoal)', 'text-anchor': 'end',
      'font-weight': 700
    }, root).textContent = fmt.format(ratio);

    // --- Magnifier callout below the bar: zoom into the leftmost edge ---
    // Show what £200K - £400K vs the rest of the bar actually means
    const magY = 260;
    const magCenterX = 200;

    // Connecting lines from sliver to magnifier
    el('line', {
      x1: barX, y1: barY + barH,
      x2: magCenterX - 60, y2: magY,
      stroke: 'var(--ml-gold)', 'stroke-width': 1, 'stroke-dasharray': '3 3', opacity: 0.6
    }, root);
    el('line', {
      x1: barX + sliverDisplayWidth, y1: barY + barH,
      x2: magCenterX + 60, y2: magY,
      stroke: 'var(--ml-gold)', 'stroke-width': 1, 'stroke-dasharray': '3 3', opacity: 0.6
    }, root);

    // Magnifier box
    const magW = 120, magH = 50;
    el('rect', {
      x: magCenterX - magW/2, y: magY, width: magW, height: magH,
      fill: 'var(--ml-gold)', rx: 2
    }, root);
    el('text', {
      x: magCenterX, y: magY + magH + 18,
      'font-size': 11, fill: 'var(--ml-charcoal)', 'text-anchor': 'middle',
      'font-weight': 600
    }, root).textContent = '1 YEAR @ £' + fmt.format(state.retainer);
    el('text', {
      x: magCenterX, y: magY + magH + 32,
      'font-size': 10, fill: 'var(--ml-slate-grey)', 'text-anchor': 'middle',
      'font-style': 'italic'
    }, root).textContent = 'magnified for visibility';

    // Central caption that sits beside the magnifier
    el('text', {
      x: 380, y: magY + 18,
      'font-size': 13, fill: 'var(--ml-charcoal)', 'text-anchor': 'start',
      'font-weight': 500
    }, root).textContent = state.costLabel + ' of governance failure =';
    const t = el('text', {
      x: 380, y: magY + 40,
      'font-size': 13, 'text-anchor': 'start'
    }, root);
    const tspan1 = el('tspan', { fill: 'var(--ml-gold)', 'font-weight': 700 }, t);
    tspan1.textContent = fmt.format(ratio) + ' years';
    const tspan2 = el('tspan', { fill: 'var(--ml-charcoal)', 'font-weight': 500, dx: 6 }, t);
    tspan2.textContent = 'of continuous SGaaS at £' + fmt.format(state.retainer) + '/yr.';

    // ----- Kick off the wipe animation -----
    if (animate) {
      const finalW = barX + barW + 80; // include label overflow on the right
      tween(0, finalW, 750, v => wipeRect.setAttribute('width', v), easeInOutQuad);
    }
  }

  // ---------- UPDATE ----------
  let current = { caseKey: 'boeing', retainer: 300000 };

  function computeState() {
    const c = cases[current.caseKey];
    const ratio = Math.round(c.costGBP / current.retainer);
    return {
      caseKey: current.caseKey,
      caseObj: c,
      retainer: current.retainer,
      costLabel: c.costLabel,
      costSub: c.costSub,
      ratio
    };
  }

  // Cached references that need to cross-fade together on case change
  const caseDetailEl = document.querySelector('.case-detail');
  const statValEls = [statFailure, statRetainer, statRatio];

  // Content that only changes on case-change (not on retainer-slider drag)
  function applyCaseContent(c) {
    heroEyebrow.innerHTML = c.eyebrow;
    statFailure.textContent = c.costLabel;
    statFailureSub.textContent = c.costSub;
    caseMeta.textContent = c.meta;
    caseHeadline.textContent = c.headline;
    caseBody.textContent = c.body;
    caseComponents.innerHTML = '';
    c.components.forEach(comp => {
      const div = document.createElement('div');
      div.className = 'component';
      div.innerHTML = '<div class="component-label">' + comp.label + '</div>' +
                      '<div class="component-value">' + comp.value + '</div>';
      caseComponents.appendChild(div);
    });
  }

  // Content that changes on EVERY render (case change OR retainer-slider drag)
  function applyLiveValues(s) {
    statRetainer.textContent = '£' + fmt.format(s.retainer);
    statRatio.textContent = fmt.format(s.ratio) + '×';
    statRatioSub.textContent = fmt.format(s.ratio) + ' years of SGaaS equivalent';
    retainerOutput.textContent = '£' + fmt.format(s.retainer);
  }

  function render(mode) {
    // mode: 'initial' | 'case' | 'slider'
    mode = mode || 'initial';
    const s = computeState();
    const c = s.caseObj;

    if (mode === 'slider') {
      // Live drag → snap update, no wipe, no fade
      heroNum.textContent = fmt.format(s.ratio);
      applyLiveValues(s);
      renderViz(s, { animate: false });
      return;
    }

    if (mode === 'case') {
      // Fade side stats + case-detail card out while the SVG wipes in fresh content
      statValEls.forEach(elem => elem.classList.add('is-swapping'));
      caseDetailEl.classList.add('is-swapping');

      setTimeout(() => {
        applyCaseContent(c);
        applyLiveValues(s);
        const fromVal = parseInt((heroNum.textContent || '0').replace(/[^\d]/g, ''), 10) || 0;
        animateNumber(fromVal, s.ratio, 950);
        renderViz(s, { animate: true });
        // Fade them back in on the next frame so the new content paints first
        requestAnimationFrame(() => {
          statValEls.forEach(elem => elem.classList.remove('is-swapping'));
          caseDetailEl.classList.remove('is-swapping');
        });
      }, 200);
      return;
    }

    // 'initial' — content swap + wipe + count-up from zero
    applyCaseContent(c);
    applyLiveValues(s);
    animateNumber(0, s.ratio, 950);
    renderViz(s, { animate: true });
  }

  // ---------- EVENTS ----------
  caseButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('active')) return; // ignore re-clicks on active case
      caseButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      current.caseKey = btn.dataset.case;
      render('case');
    });
  });

  retainerSlider.addEventListener('input', e => {
    current.retainer = parseInt(e.target.value, 10) * 1000;
    render('slider');
  });

  // Initial render: wipe animation + count-up from 0
  render('initial');
})();
</script>

<script>
(function(){
  try {
    var p = new URLSearchParams(window.location.search);
    if (p.get('embed') === '1') {
      document.body.classList.add('embed-mode');
      var sendHeight = function(){
        try {
          // Measure body content only. documentElement.scrollHeight is floored
          // to the iframe's viewport height, which would feed back into a
          // resize loop once the parent applied the height.
          var rect = document.body.getBoundingClientRect();
          var h = Math.max(document.body.scrollHeight, Math.ceil(rect.height));
          if (window.parent && window.parent !== window) {
            window.parent.postMessage({ type: 'mlInteractiveHeight', height: h }, '*');
          }
        } catch(err) {}
      };
      if (document.readyState === 'complete') sendHeight();
      else window.addEventListener('load', sendHeight);
      window.addEventListener('resize', sendHeight);
      setTimeout(sendHeight, 250);
      setTimeout(sendHeight, 800);
      setTimeout(sendHeight, 1800);
    }
  } catch(e) {}
})();
</script>
