  .component-label {
    font-size: 11px;
    color: var(--ml-slate-grey);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .component-value {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 18px;
    color: var(--ml-charcoal);
