<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
  <div class="container mx-auto px-6 py-4 flex justify-between items-center">

    <!-- Logo -->
    <a href="/" class="flex items-center space-x-3 flex-shrink-0">
      <img src="/assets/images/Marentis_Labs_NoTag_Logo.png"
           alt="Marentis Labs"
           class="h-[67px] md:h-[90px] w-auto object-contain" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center space-x-7" aria-label="Main navigation">
      <a href="/" class="nav-link {% if page.url == '/' %}nav-link-active{% endif %}">Home</a>
      <a href="/services/" class="nav-link {% if page.url contains '/services' %}nav-link-active{% endif %}">Services</a>
      <a href="/about/" class="nav-link {% if page.url contains '/about' %}nav-link-active{% endif %}">About</a>
      <a href="/case-studies/" class="nav-link {% if page.url contains '/case-studies' %}nav-link-active{% endif %}">Case Studies</a>
      <a href="/insights/" class="nav-link {% if page.url contains '/insights' %}nav-link-active{% endif %}">Insights</a>
      <a href="/contact/" class="btn-nav-cta ml-2">Confidential Call &rarr;</a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-button"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="md:hidden focus:outline-none p-1">
      <!-- Open icon -->
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-ml-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close icon (hidden by default) -->
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-ml-charcoal hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg" role="navigation" aria-label="Mobile navigation">
    <div class="container mx-auto px-6 py-4 flex flex-col space-y-3">
      <a href="/"          class="nav-link py-2 {% if page.url == '/' %}nav-link-active{% endif %}">Home</a>
      <a href="/services/" class="nav-link py-2 {% if page.url contains '/services' %}nav-link-active{% endif %}">Services</a>
      <a href="/about/"         class="nav-link py-2 {% if page.url contains '/about' %}nav-link-active{% endif %}">About</a>
      <a href="/case-studies/" class="nav-link py-2 {% if page.url contains '/case-studies' %}nav-link-active{% endif %}">Case Studies</a>
      <a href="/insights/"     class="nav-link py-2 {% if page.url contains '/insights' %}nav-link-active{% endif %}">Insights</a>
      <a href="/contact/"  class="btn-nav-cta text-center mt-2">Confidential Call &rarr;</a>
    </div>
  </div>
</header>
